#!/usr/bin/env bash
# Manta Pre-Commit Hook
# Runs multi-agent code review on staged changes.
# Blocks commit if CRITICAL issues are found.
# Supports: Claude Code (claude), OpenAI Codex CLI (codex), Google Gemini CLI (gemini)
#
# Setup: run scripts/setup.sh (or: git config core.hooksPath .githooks)

set -euo pipefail

# ─── Colors ──────────────────────────────────────────────────────────────────
RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
CYAN='\033[0;36m'
BOLD='\033[1m'
RESET='\033[0m'

# ─── AI tool detection ────────────────────────────────────────────────────────
# Supports: Claude Code (claude), OpenAI Codex CLI (codex), Google Gemini CLI (gemini)
# Override with: AI_BIN=gemini git commit
# Legacy override: CLAUDE_BIN=claude git commit

detect_ai_tool() {
  if [[ -n "${AI_BIN:-}" ]] && command -v "$AI_BIN" &>/dev/null; then
    echo "$AI_BIN"; return
  fi
  if [[ -n "${CLAUDE_BIN:-}" ]] && command -v "${CLAUDE_BIN}" &>/dev/null; then
    echo "${CLAUDE_BIN}"; return
  fi
  if command -v claude &>/dev/null; then echo "claude"; return; fi
  if command -v codex &>/dev/null; then echo "codex"; return; fi
  if command -v gemini &>/dev/null; then echo "gemini"; return; fi
  echo ""
}

run_ai_review() {
  local tool="$1"
  local prompt="$2"
  local hook_timeout="${3:-120}"
  case "$tool" in
    claude) timeout "$hook_timeout" claude --print "$prompt" 2>&1 ;;
    codex)  timeout "$hook_timeout" codex -q "$prompt" 2>&1 ;;
    gemini) timeout "$hook_timeout" gemini -p "$prompt" 2>&1 ;;
    *)      return 1 ;;
  esac
}

AI_TOOL=$(detect_ai_tool)

# ─── Locate Manta directory ───────────────────────────────────────────────────
# Works whether Manta is at the project root or in a subfolder (e.g. project/manta/)
HOOK_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
MANTA_DIR="$(cd "$HOOK_DIR/.." && pwd)"
GIT_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"

# ─── Config ───────────────────────────────────────────────────────────────────
CLAUDE_BIN="${CLAUDE_BIN:-claude}"  # kept for backward compat
HOOK_TIMEOUT="${CLAUDE_HOOK_TIMEOUT:-120}"  # seconds before giving up (whole review)
SKIP_VAR="SKIP_CLAUDE_REVIEW"

# Per-agent timeouts (informational — enforced inside the review command)
AGENT_TIMEOUT_SENTINEL="${AGENT_TIMEOUT_SENTINEL:-90}"
AGENT_TIMEOUT_QUALITY="${AGENT_TIMEOUT_QUALITY:-45}"
AGENT_TIMEOUT_PERF="${AGENT_TIMEOUT_PERF:-30}"
AGENT_TIMEOUT_DB="${AGENT_TIMEOUT_DB:-20}"
export AGENT_TIMEOUT_SENTINEL AGENT_TIMEOUT_QUALITY AGENT_TIMEOUT_PERF AGENT_TIMEOUT_DB

# ─── Skip check ───────────────────────────────────────────────────────────────
if [[ "${!SKIP_VAR:-}" == "1" ]]; then
  echo -e "${YELLOW}[manta]${RESET} Review skipped (${SKIP_VAR}=1)"
  exit 0
fi

# ─── Check AI tool is available ───────────────────────────────────────────────
if [[ -z "$AI_TOOL" ]]; then
  echo -e "${YELLOW}[manta]${RESET} Warning: no AI CLI found — skipping review"
  echo "         Install one of: claude (npm i -g @anthropic-ai/claude-code), codex (npm i -g @openai/codex), gemini (npm i -g @google/gemini-cli)"
  echo "         Or set SKIP_CLAUDE_REVIEW=1 to bypass"
  exit 0
fi

# ─── Check for staged files ────────────────────────────────────────────────────
STAGED_FILES=$(git diff --cached --name-only 2>/dev/null)
if [[ -z "$STAGED_FILES" ]]; then
  exit 0
fi

# ─── Skip non-code files only commits ─────────────────────────────────────────
STAGED_CODE_FILES=$(git diff --cached --name-only | grep -E '\.(ts|tsx|js|jsx|mjs|cjs|py|go|rs|rb|java|kt|swift|c|cpp|h|hpp|cs|php|sh|bash)$' || true)
if [[ -z "$STAGED_CODE_FILES" ]]; then
  echo -e "${CYAN}[manta/${AI_TOOL}]${RESET} Only non-code files staged — skipping code review"
  exit 0
fi

# ─── Run review ───────────────────────────────────────────────────────────────
echo ""
echo -e "${CYAN}${BOLD}┌─────────────────────────────────────────────────┐${RESET}"
echo -e "${CYAN}${BOLD}│           Manta Pre-Commit Review               │${RESET}"
echo -e "${CYAN}${BOLD}└─────────────────────────────────────────────────┘${RESET}"
echo ""
echo -e "${CYAN}[manta/${AI_TOOL}]${RESET} Reviewing $(echo "$STAGED_CODE_FILES" | wc -l | tr -d ' ') staged file(s)..."

# ─── Shallow pre-scan ─────────────────────────────────────────────────────────
SHALLOW_RESULT=""
if [[ -f "$MANTA_DIR/scripts/shallow-scan.sh" ]]; then
  SHALLOW_RESULT=$(cd "$GIT_ROOT" && bash "$MANTA_DIR/scripts/shallow-scan.sh" 2>/dev/null || true)
  SHALLOW_STATUS=$(echo "$SHALLOW_RESULT" | grep "^SHALLOW_SCAN:" | cut -d' ' -f2 || echo "UNKNOWN")
  SIGNAL_COUNT=$(echo "$SHALLOW_RESULT" | grep "^SIGNALS:" | cut -d' ' -f2 || echo "0")

  if [[ "$SHALLOW_STATUS" == "SIGNALS_FOUND" ]]; then
    echo -e "${YELLOW}[manta]${RESET} Shallow scan: ${SIGNAL_COUNT} signal(s) — running full agent review"
  else
    echo -e "${GREEN}[manta]${RESET} Shallow scan: clean — running optimized review"
  fi
fi

# ─── Project map ─────────────────────────────────────────────────────────────
if [[ -f "$MANTA_DIR/scripts/build-project-map.sh" ]]; then
  cd "$GIT_ROOT" && bash "$MANTA_DIR/scripts/build-project-map.sh" > /dev/null 2>&1 || true
fi

echo -e "${CYAN}[manta/${AI_TOOL}]${RESET} Running: security-sentinel, code-quality, perf-analyzer, db-migration-guardian"
echo ""

# Build the review prompt
REVIEW_PROMPT=$(cat "$MANTA_DIR/.claude/commands/pre-commit-review.md" 2>/dev/null || echo "Review the staged git changes. Check for critical issues in code quality, security vulnerabilities, and performance. Output COMMIT_VERDICT: PASS or COMMIT_VERDICT: BLOCK.")

# Run AI review
REVIEW_OUTPUT=""
CLAUDE_EXIT=0

REVIEW_OUTPUT=$(
  cd "$MANTA_DIR" && \
  GIT_DIR="$GIT_ROOT/.git" GIT_WORK_TREE="$GIT_ROOT" \
  run_ai_review "$AI_TOOL" "$REVIEW_PROMPT" "$HOOK_TIMEOUT"
) || CLAUDE_EXIT=$?

# ─── Handle timeout or error ──────────────────────────────────────────────────
if [[ $CLAUDE_EXIT -eq 124 ]]; then
  echo -e "${YELLOW}[manta]${RESET} Review timed out after ${HOOK_TIMEOUT}s — allowing commit"
  echo "         Increase timeout: export CLAUDE_HOOK_TIMEOUT=180"
  exit 0
fi

if [[ $CLAUDE_EXIT -ne 0 ]] && ! echo "$REVIEW_OUTPUT" | grep -q "COMMIT_VERDICT"; then
  echo -e "${YELLOW}[manta]${RESET} Review encountered an error — allowing commit"
  echo "         Error: $REVIEW_OUTPUT" | head -5
  exit 0
fi

# ─── Display review output ────────────────────────────────────────────────────
echo "$REVIEW_OUTPUT"
echo ""

# ─── Save review to reports/ ──────────────────────────────────────────────────
REPORT_DATE=$(date +%Y-%m-%d)
REPORT_TIME=$(date +%H%M)
REPORT_FILE="$GIT_ROOT/reports/${REPORT_DATE}-${REPORT_TIME}-commit-review.md"
mkdir -p "$GIT_ROOT/reports"
{
  printf "# Pre-Commit Review — %s %s\n\n" "$REPORT_DATE" "$(date +%H:%M)"
  printf "**Branch**: \`%s\`  \n" "$(git -C "$GIT_ROOT" branch --show-current 2>/dev/null)"
  printf "**Files reviewed**: %s\n\n" "$(echo "$STAGED_CODE_FILES" | wc -l | tr -d ' ')"
  printf "**Staged files**:\n\`\`\`\n%s\n\`\`\`\n\n" "$STAGED_CODE_FILES"
  printf "---\n\n"
  printf "%s\n" "$REVIEW_OUTPUT"
} > "$REPORT_FILE"
echo -e "${CYAN}[manta]${RESET} Review saved: ${REPORT_FILE}"
echo ""

# ─── Parse verdict ────────────────────────────────────────────────────────────
if echo "$REVIEW_OUTPUT" | grep -q "COMMIT_VERDICT: BLOCK"; then
  BLOCK_REASON=$(echo "$REVIEW_OUTPUT" | grep "BLOCK_REASON:" | sed 's/BLOCK_REASON: //' || echo "Critical issues found")

  echo ""
  echo -e "${RED}${BOLD}╔═══════════════════════════════════════════════════╗${RESET}"
  echo -e "${RED}${BOLD}║              COMMIT BLOCKED 🚫                   ║${RESET}"
  echo -e "${RED}${BOLD}╚═══════════════════════════════════════════════════╝${RESET}"
  echo ""
  echo -e "${RED}${BOLD}$BLOCK_REASON${RESET}"
  echo ""
  echo -e "${YELLOW}Fix the critical issues above, then commit again.${RESET}"
  echo -e "${CYAN}Get AI fix suggestions:${RESET} open Claude Code (${BOLD}/project:fix${RESET}) or ask your AI assistant"
  echo ""
  echo -e "To bypass (emergency only): ${BOLD}SKIP_CLAUDE_REVIEW=1 git commit${RESET}"
  echo ""
  exit 1

elif echo "$REVIEW_OUTPUT" | grep -q "COMMIT_VERDICT: WARN"; then
  WARN_REASON=$(echo "$REVIEW_OUTPUT" | grep "BLOCK_REASON:" | sed 's/BLOCK_REASON: //' || echo "Warnings found")

  echo ""
  echo -e "${YELLOW}${BOLD}╔═══════════════════════════════════════════════════╗${RESET}"
  echo -e "${YELLOW}${BOLD}║          COMMIT ALLOWED — WARNINGS ⚠             ║${RESET}"
  echo -e "${YELLOW}${BOLD}╚═══════════════════════════════════════════════════╝${RESET}"
  echo ""
  echo -e "${YELLOW}${BOLD}$WARN_REASON${RESET}"
  echo ""
  echo -e "${YELLOW}Warnings above should be addressed before pushing.${RESET}"
  echo -e "${CYAN}Get AI fix suggestions:${RESET} open Claude Code (${BOLD}/project:fix${RESET}) or ask your AI assistant"
  echo -e "${YELLOW}Note:${RESET} Warnings ${BOLD}will block${RESET} the pre-push review."
  echo ""
  exit 0

elif echo "$REVIEW_OUTPUT" | grep -q "COMMIT_VERDICT: PASS"; then
  echo -e "${GREEN}${BOLD}✅ Review passed — proceeding with commit${RESET}"
  echo ""
  exit 0

else
  # No clear verdict found — allow commit but warn
  echo -e "${YELLOW}[manta]${RESET} Could not parse review verdict — allowing commit"
  echo "         Run /project:review in Claude Code for a full interactive review"
  exit 0
fi
