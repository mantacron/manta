#!/usr/bin/env bash
# Manta Pre-Push Hook
# Runs a 3–4 agent review on the branch diff before push (db-migration trigger-routed).
# Blocks push if CRITICAL or WARNING issues are found (security, quality, perf, migrations).
# Supports: Claude Code (claude), OpenAI Codex CLI (codex), Google Gemini CLI (gemini)
#
# Setup: run scripts/setup.sh (or: git config core.hooksPath .githooks)

set -euo pipefail

# ─── Colors ──────────────────────────────────────────────────────────────────
RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
CYAN='\033[0;36m'
BOLD='\033[1m'
RESET='\033[0m'

# ─── AI tool detection ────────────────────────────────────────────────────────
# Supports: Claude Code (claude), OpenAI Codex CLI (codex), Google Gemini CLI (gemini)
# Override with: AI_BIN=gemini git push
# Legacy override: CLAUDE_BIN=claude git push

detect_ai_tool() {
  if [[ -n "${AI_BIN:-}" ]] && command -v "$AI_BIN" &>/dev/null; then
    echo "$AI_BIN"; return
  fi
  if [[ -n "${CLAUDE_BIN:-}" ]] && command -v "${CLAUDE_BIN}" &>/dev/null; then
    echo "${CLAUDE_BIN}"; return
  fi
  if command -v claude &>/dev/null; then echo "claude"; return; fi
  if command -v codex &>/dev/null; then echo "codex"; return; fi
  if command -v gemini &>/dev/null; then echo "gemini"; return; fi
  echo ""
}

run_ai_review() {
  local tool="$1"
  local prompt="$2"
  local hook_timeout="${3:-180}"
  case "$tool" in
    claude) timeout "$hook_timeout" claude --print "$prompt" 2>&1 ;;
    codex)  timeout "$hook_timeout" codex -q "$prompt" 2>&1 ;;
    gemini) timeout "$hook_timeout" gemini -p "$prompt" 2>&1 ;;
    *)      return 1 ;;
  esac
}

AI_TOOL=$(detect_ai_tool)

# ─── Locate Manta directory ───────────────────────────────────────────────────
HOOK_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
MANTA_DIR="$(cd "$HOOK_DIR/.." && pwd)"
GIT_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"

# ─── Config ───────────────────────────────────────────────────────────────────
CLAUDE_BIN="${CLAUDE_BIN:-claude}"  # kept for backward compat
HOOK_TIMEOUT="${CLAUDE_HOOK_TIMEOUT:-180}"
SKIP_VAR="SKIP_CLAUDE_PUSH_REVIEW"

# ─── Skip check ───────────────────────────────────────────────────────────────
if [[ "${!SKIP_VAR:-}" == "1" ]]; then
  echo -e "${YELLOW}[manta]${RESET} Push review skipped (${SKIP_VAR}=1)"
  exit 0
fi

# ─── Check AI tool is available ───────────────────────────────────────────────
if [[ -z "$AI_TOOL" ]]; then
  echo -e "${YELLOW}[manta]${RESET} Warning: no AI CLI found — skipping push review"
  echo "         Install one of: claude (npm i -g @anthropic-ai/claude-code), codex (npm i -g @openai/codex), gemini (npm i -g @google/gemini-cli)"
  exit 0
fi

# ─── Read push info from stdin ────────────────────────────────────────────────
# Git passes: <local-ref> <local-sha> <remote-ref> <remote-sha>
PUSH_INFO=$(cat)
LOCAL_SHA=$(echo "$PUSH_INFO" | awk '{print $2}' | head -1)
REMOTE_SHA=$(echo "$PUSH_INFO" | awk '{print $4}' | head -1)

# Handle new branch (remote SHA is all zeros)
if [[ "$REMOTE_SHA" == "0000000000000000000000000000000000000000" ]]; then
  # New branch — diff against main/master
  BASE_BRANCH=$(git symbolic-ref refs/remotes/origin/HEAD 2>/dev/null | sed 's@^refs/remotes/origin/@@' || echo "main")
  REMOTE_SHA=$(git merge-base "origin/$BASE_BRANCH" "$LOCAL_SHA" 2>/dev/null || echo "")
fi

if [[ -z "$REMOTE_SHA" ]]; then
  echo -e "${CYAN}[manta]${RESET} Cannot determine base — skipping push review"
  exit 0
fi

# ─── Check if there are code changes ─────────────────────────────────────────
CHANGED_FILES=$(git diff --name-only "$REMOTE_SHA" "$LOCAL_SHA" 2>/dev/null | grep -E '\.(ts|tsx|js|jsx|py|go|rs|rb|java|kt|c|cpp|cs|php)$' || true)

if [[ -z "$CHANGED_FILES" ]]; then
  exit 0
fi

FILE_COUNT=$(echo "$CHANGED_FILES" | wc -l | tr -d ' ')

echo ""
echo -e "${CYAN}${BOLD}┌─────────────────────────────────────────────────┐${RESET}"
echo -e "${CYAN}${BOLD}│            Manta Pre-Push Review                │${RESET}"
echo -e "${CYAN}${BOLD}└─────────────────────────────────────────────────┘${RESET}"
echo ""
echo -e "${CYAN}[manta/${AI_TOOL}]${RESET} Reviewing ${FILE_COUNT} file(s) — security, quality, performance, database migrations..."
echo ""

# ─── Build review prompt from command file ────────────────────────────────────
# Export SHAs so pre-push-review.md can reference them in git diff instructions
export LOCAL_SHA REMOTE_SHA

PROMPT=$(cat "$MANTA_DIR/.claude/commands/pre-push-review.md" 2>/dev/null || echo "Review the branch diff for CRITICAL issues across security, code quality, and performance. Output PUSH_VERDICT: PASS or PUSH_VERDICT: BLOCK.")

# ─── Run AI review ────────────────────────────────────────────────────────────
SCAN_OUTPUT=""
CLAUDE_EXIT=0

SCAN_OUTPUT=$(
  cd "$MANTA_DIR" && \
  GIT_DIR="$GIT_ROOT/.git" GIT_WORK_TREE="$GIT_ROOT" \
  run_ai_review "$AI_TOOL" "$PROMPT" "$HOOK_TIMEOUT"
) || CLAUDE_EXIT=$?

# ─── Handle errors ────────────────────────────────────────────────────────────
if [[ $CLAUDE_EXIT -eq 124 ]]; then
  echo -e "${YELLOW}[manta]${RESET} Push review timed out — allowing push"
  exit 0
fi

if [[ $CLAUDE_EXIT -ne 0 ]] && ! echo "$SCAN_OUTPUT" | grep -q "PUSH_VERDICT"; then
  echo -e "${YELLOW}[manta]${RESET} Push review error — allowing push"
  exit 0
fi

# ─── Display output ───────────────────────────────────────────────────────────
echo "$SCAN_OUTPUT"
echo ""

# ─── Save scan to reports/ ────────────────────────────────────────────────────
REPORT_DATE=$(date +%Y-%m-%d)
REPORT_TIME=$(date +%H%M)
REPORT_FILE="$GIT_ROOT/reports/${REPORT_DATE}-${REPORT_TIME}-push-review.md"
mkdir -p "$GIT_ROOT/reports"
{
  printf "# Pre-Push Security Scan — %s %s\n\n" "$REPORT_DATE" "$(date +%H:%M)"
  printf "**Branch**: \`%s\`  \n" "$(git -C "$GIT_ROOT" branch --show-current 2>/dev/null)"
  printf "**Commits scanned**: \`%s\` → \`%s\`\n\n" \
    "$(echo "$REMOTE_SHA" | cut -c1-7)" "$(echo "$LOCAL_SHA" | cut -c1-7)"
  printf "**Files scanned**: %s\n\n" "$FILE_COUNT"
  printf "---\n\n"
  printf "%s\n" "$SCAN_OUTPUT"
} > "$REPORT_FILE"
echo -e "${CYAN}[manta]${RESET} Scan saved: ${REPORT_FILE}"
echo ""

# ─── Parse verdict ────────────────────────────────────────────────────────────
if echo "$SCAN_OUTPUT" | grep -q "PUSH_VERDICT: BLOCK"; then
  BLOCK_REASON=$(echo "$SCAN_OUTPUT" | grep "BLOCK_REASON:" | sed 's/BLOCK_REASON: //' || echo "Critical issues found")

  echo ""
  echo -e "${RED}${BOLD}╔═══════════════════════════════════════════════════╗${RESET}"
  echo -e "${RED}${BOLD}║              PUSH BLOCKED 🚫                     ║${RESET}"
  echo -e "${RED}${BOLD}╚═══════════════════════════════════════════════════╝${RESET}"
  echo ""
  echo -e "${RED}${BOLD}$BLOCK_REASON${RESET}"
  echo ""
  echo -e "${YELLOW}Fix the critical issues above, then push again.${RESET}"
  echo -e "${CYAN}Get AI fix suggestions:${RESET} open Claude Code (${BOLD}/project:fix${RESET}) or ask your AI assistant"
  echo -e "To bypass (emergency only): ${BOLD}SKIP_CLAUDE_PUSH_REVIEW=1 git push${RESET}"
  echo ""
  exit 1

elif echo "$SCAN_OUTPUT" | grep -q "PUSH_VERDICT: WARN"; then
  BLOCK_REASON=$(echo "$SCAN_OUTPUT" | grep "BLOCK_REASON:" | sed 's/BLOCK_REASON: //' || echo "Warnings found")

  echo ""
  echo -e "${YELLOW}${BOLD}╔═══════════════════════════════════════════════════╗${RESET}"
  echo -e "${YELLOW}${BOLD}║           PUSH BLOCKED — WARNINGS ⚠             ║${RESET}"
  echo -e "${YELLOW}${BOLD}╚═══════════════════════════════════════════════════╝${RESET}"
  echo ""
  echo -e "${YELLOW}${BOLD}$BLOCK_REASON${RESET}"
  echo ""
  echo -e "${YELLOW}Warnings must be resolved before pushing.${RESET}"
  echo -e "${CYAN}Get AI fix suggestions:${RESET} open Claude Code (${BOLD}/project:fix${RESET}) or ask your AI assistant"
  echo -e "To bypass (emergency only): ${BOLD}SKIP_CLAUDE_PUSH_REVIEW=1 git push${RESET}"
  echo ""
  exit 1

else
  echo -e "${GREEN}${BOLD}✅ Review passed — pushing${RESET}"
  echo ""
  exit 0
fi
